# Banco de dados — Supabase (PostgreSQL)
# Pooler (Vercel / produção / app rodando):
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use o host pooler (aws-0-REGIAO.pooler.supabase.com), não db.xxx.supabase.co na Vercel
# Conexão direta (migrations / db:push / db:seed no seu PC):
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:5432/postgres"

# Alternativa local com SQLite (só dev, NÃO funciona na Vercel):
# DATABASE_URL="file:./dev.db"
# Remova DIRECT_URL e volte provider para sqlite em prisma/schema.prisma

# NextAuth
AUTH_SECRET="gere-um-secret-aleatorio-aqui"
AUTH_URL="http://localhost:3000"

# OAuth (opcional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Stripe (obrigatório para receber pagamentos)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Crie produtos no Stripe Dashboard → copie os Price IDs (mensal, EUR)
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_BUSINESS="price_..."

# UploadThing
UPLOADTHING_TOKEN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Nexly"

# Conta demo (só você — não commitar valores reais)
DEMO_ACCESS_SECRET="gere-uma-chave-secreta-longa"
DEMO_PASSWORD="senha-forte-só-sua"
